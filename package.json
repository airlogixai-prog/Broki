{
  "name": "broki",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix web",
    "build": "npm run build --prefix web",
    "start": "npm run start --prefix web",
    "lint": "npm run lint --prefix web",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > web/src/lib/supabase/database.types.ts",
    "db:push": "supabase db push",
    "functions:deploy": "supabase functions deploy --use-api",
    "functions:secrets": "supabase secrets set N8N_BASE_URL=https://n8n.airlogixai.com/webhook"
  },
  "devDependencies": {
    "supabase": "^2.106.0"
  }
}
